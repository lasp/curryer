{
  "_comment": "Generic correction config template in the three-section schema (setup / sweep / output). Copy this file, replace the placeholder paths and parameter specs, then load with load_config_files(). Top-level keys starting with '_' are documentation only and are ignored by the loader.",
  "setup": {
    "geo": {
      "meta_kernel_file": "path/to/your_mission.kernels.tm.json",
      "generic_kernel_dir": "data/generic",
      "instrument_name": "YOUR_INSTRUMENT",
      "time_field": "YOUR_TIME_COLUMN",
      "dynamic_kernels": [
        "path/to/sc_ephemeris.spk.json",
        "path/to/sc_attitude.ck.json"
      ]
    },
    "requirements": {
      "performance_threshold_m": 250.0,
      "performance_spec_percent": 39.0
    },
    "data_config": {
      "file_format": "csv",
      "time_scale_factor": 1.0
    },
    "spacecraft_position_name": "sc_position",
    "boresight_name": "boresight",
    "transformation_matrix_name": "t_inst2ref"
  },
  "sweep": {
    "search_strategy": "random",
    "seed": 42,
    "n_iterations": 50,
    "parameters": [
      {
        "ptype": "CONSTANT_KERNEL",
        "config_file": "path/to/frame_a.attitude.ck.json",
        "spec": {
          "current_value": [0.0, 0.0, 0.0],
          "bounds": [-300.0, 300.0],
          "sigma": 50.0,
          "units": "arcseconds",
          "transformation_type": "dcm_rotation",
          "coordinate_frames": ["FRAME_A_FROM", "FRAME_A_TO"]
        }
      },
      {
        "ptype": "OFFSET_KERNEL",
        "config_file": "path/to/sensor_az.attitude.ck.json",
        "spec": {
          "field": "YOUR_TELEMETRY_FIELD",
          "current_value": 0.0,
          "bounds": [-300.0, 300.0],
          "sigma": 30.0,
          "units": "arcseconds",
          "transformation_type": "angle_bias",
          "coordinate_frames": ["SENSOR_AZIMUTH"]
        }
      },
      {
        "ptype": "OFFSET_TIME",
        "config_file": null,
        "spec": {
          "field": "YOUR_TIME_FIELD",
          "current_value": 0.0,
          "bounds": [-50.0, 50.0],
          "sigma": 7.0,
          "units": "milliseconds"
        }
      }
    ]
  },
  "output": {
    "netcdf": {
      "performance_threshold_m": 250.0,
      "title": "Correction Geolocation Analysis Results",
      "description": "Parameter sensitivity analysis"
    },
    "output_filename": "correction_results.nc"
  }
}
